{
  "version": 10,
  "cmakeMinimumRequired": {
    "major": 3,
    "minor": 31,
    "patch": 0
  },
  "configurePresets": [
    {
      "name": "base-config",
      "hidden": true,
      "description": "Platform agnostic configuration.",
      "generator": "Ninja",
      "binaryDir": "${sourceDir}/build/${presetName}",
      "cacheVariables": {
        "CMAKE_CXX_STANDARD": "26",
        "CMAKE_CXX_STANDARD_REQUIRED": "ON",
        "CMAKE_EXPORT_COMPILE_COMMANDS": "ON",
        "CMAKE_RUNTIME_OUTPUT_DIRECTORY": "${sourceDir}/out/bin/${presetName}",
        "CMAKE_LIBRARY_OUTPUT_DIRECTORY": "${sourceDir}/out/lib/${presetName}",
        "CMAKE_ARCHIVE_OUTPUT_DIRECTORY": "${sourceDir}/out/lib/${presetName}"
      }
    },
    {
      "name": "dev",
      "inherits": "base-config",
      "description": "Default development preset.",
      "cacheVariables": {
        "CMAKE_CXX_COMPILER": "g++",
        "CMAKE_BUILD_TYPE": "Debug"
      }
    },
    {
      "name": "x64-clang-debug",
      "inherits": "base-config",
      "description": "Compile with clang++ in Debug mode.",
      "cacheVariables": {
        "CMAKE_CXX_COMPILER": "clang++",
        "CMAKE_BUILD_TYPE": "Debug"
      }
    },
    {
      "name": "x64-clang-release",
      "inherits": "base-config",
      "description": "Compile with clang++ in Release mode.",
      "cacheVariables": {
        "CMAKE_CXX_COMPILER": "clang++",
        "CMAKE_BUILD_TYPE": "Release"
      }
    },
    {
      "name": "x64-gcc-debug",
      "inherits": "base-config",
      "description": "Compile with g++ in Debug mode.",
      "cacheVariables": {
        "CMAKE_CXX_COMPILER": "g++",
        "CMAKE_BUILD_TYPE": "Debug"
      }
    },
    {
      "name": "x64-gcc-release",
      "inherits": "base-config",
      "description": "Compile with g++ in Release mode.",
      "cacheVariables": {
        "CMAKE_CXX_COMPILER": "g++",
        "CMAKE_BUILD_TYPE": "Release"
      }
    },
    {
      "name": "x64-msvc-debug",
      "inherits": "base-config",
      "description": "Compile with MSVC in Debug mode.",
      "cacheVariables": {
        "CMAKE_CXX_COMPILER": "cl",
        "CMAKE_BUILD_TYPE": "Debug"
      }
    },
    {
      "name": "x64-msvc-release",
      "inherits": "base-config",
      "description": "Compile with MSVC in Release mode.",
      "cacheVariables": {
        "CMAKE_CXX_COMPILER": "cl",
        "CMAKE_BUILD_TYPE": "Release"
      }
    }
  ],
  "buildPresets": [
    {
      "name": "dev",
      "configurePreset": "dev"
    },
    {
      "name": "x64-clang-debug",
      "configurePreset": "x64-clang-debug"
    },
    {
      "name": "x64-clang-release",
      "configurePreset": "x64-clang-release"
    },
    {
      "name": "x64-gcc-debug",
      "configurePreset": "x64-gcc-debug"
    },
    {
      "name": "x64-gcc-release",
      "configurePreset": "x64-gcc-release"
    },
    {
      "name": "x64-msvc-debug",
      "configurePreset": "x64-msvc-debug"
    },
    {
      "name": "x64-msvc-release",
      "configurePreset": "x64-msvc-release"
    }
  ],
  "testPresets": [
    {
      "name": "x64-clang-debug",
      "configurePreset": "x64-clang-debug",
      "output": { "outputOnFailure": true }
    },
    {
      "name": "x64-gcc-debug",
      "configurePreset": "x64-gcc-debug",
      "output": { "outputOnFailure": true }
    }
  ]
}
